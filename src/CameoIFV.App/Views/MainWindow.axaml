<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CameoIFV.App.ViewModels"
        xmlns:model="using:CameoIFV.Core.Model"
        xmlns:gh="using:CameoIFV.Core.Github"
        xmlns:inst="using:CameoIFV.Core.Install"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="760" d:DesignHeight="520"
        x:Class="CameoIFV.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="900" Height="660"
        WindowStartupLocation="CenterScreen"
        Title="{Binding WindowTitle}">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <!-- Accent buttons. We recolor the templated ContentPresenter for the resting, hover and
             pressed states; the disabled state is left to the theme so disabled buttons still gray out.
             The :not(:disabled) guard keeps the resting colour from leaking onto a disabled button. -->

        <!-- Refresh: teal -->
        <Style Selector="Button.teal:not(:disabled) /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1F8A8A"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.teal:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#26A3A3"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.teal:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#176E6E"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Play: dark green -->
        <Style Selector="Button.play:not(:disabled) /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1B6E2E"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.play:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#228539"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.play:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#155724"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Delete: red -->
        <Style Selector="Button.danger:not(:disabled) /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#B33A3A"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#C94A4A"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.danger:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#8F2E2E"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Styles>

    <DockPanel>

    <!-- Launcher self-update banner (shown only when a newer release is available) -->
    <Border DockPanel.Dock="Top" IsVisible="{Binding IsLauncherUpdateAvailable}"
            Background="#2D4A22" Padding="12,8">
        <Grid ColumnDefinitions="*,Auto,Auto">
            <TextBlock Grid.Column="0" Text="{Binding LauncherUpdateBanner}" VerticalAlignment="Center" TextWrapping="Wrap"/>
            <Button Grid.Column="1" Content="Update &amp; restart" Command="{Binding ApplyLauncherUpdateCommand}" Margin="8,0,0,0"/>
            <Button Grid.Column="2" Content="Dismiss" Command="{Binding DismissLauncherUpdateCommand}" Margin="8,0,0,0"/>
        </Grid>
    </Border>

    <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto" ColumnDefinitions="*,16,*">

        <!-- Mod picker -->
        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Mod" VerticalAlignment="Center"/>
            <ComboBox MinWidth="160" ItemsSource="{Binding Mods}" SelectedItem="{Binding SelectedMod}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="model:ModDefinition">
                        <TextBlock Text="{Binding DisplayName}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="Channel" VerticalAlignment="Center"/>
            <ComboBox MinWidth="240" ItemsSource="{Binding Channels}" SelectedItem="{Binding SelectedChannel}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:ChannelOption">
                        <TextBlock Text="{Binding Label}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Content="Refresh" Classes="teal" Command="{Binding RefreshReleasesCommand}"/>
        </StackPanel>

        <!-- Library location -->
        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,10,0,0" ColumnSpacing="8">
            <TextBlock Grid.Column="0" Text="Library" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" ItemsSource="{Binding LibraryRoots}" SelectedItem="{Binding SelectedLibraryRoot}" VerticalAlignment="Center"/>
            <Button Grid.Column="2" Content="Add path..." Command="{Binding AddLibraryCommand}"/>
            <Button Grid.Column="3" Content="{Binding RemoveLibraryButtonText}" Command="{Binding RemoveLibraryCommand}"/>
        </Grid>

        <!-- Column headers -->
        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,12,0,4" FontWeight="Bold" Text="Available"/>
        <TextBlock Grid.Row="2" Grid.Column="2" Margin="0,12,0,4" FontWeight="Bold" Text="Installed"/>

        <!-- Available releases -->
        <ListBox Grid.Row="3" Grid.Column="0" ItemsSource="{Binding AvailableReleases}" SelectedItem="{Binding SelectedRelease}">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="gh:ResolvedRelease">
                    <StackPanel>
                        <TextBlock Text="{Binding TagName}" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding TimelineLabel}" Opacity="0.7" FontSize="11"/>
                            <TextBlock Text="• incremental" FontSize="11" Foreground="#3a8" IsVisible="{Binding SupportsIncrementalUpdate}"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Installed instances -->
        <ListBox Grid.Row="3" Grid.Column="2" ItemsSource="{Binding InstalledInstances}" SelectedItem="{Binding SelectedInstance}">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="inst:InstalledInstance">
                    <StackPanel>
                        <TextBlock Text="{Binding DisplayVersion}" FontWeight="SemiBold"/>
                        <TextBlock Text="not runnable" FontSize="11" Foreground="#c55" IsVisible="{Binding !IsRunnable}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Action buttons -->
        <StackPanel Grid.Row="4" Grid.Column="0" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <Button Content="Install / Update" FontWeight="Bold" Command="{Binding InstallCommand}"/>
            <Button Content="Cancel" Command="{Binding CancelInstallCommand}"/>
            <CheckBox Content="Update in place" IsChecked="{Binding SingleInstanceMode}" VerticalAlignment="Center"
                      ToolTip.Tip="Keep one instance folder for this mod and overwrite it on each update — the game's path stays the same (desktop shortcuts keep working) and old versions don't pile up. The previous version's folders are removed after the next successful update."/>
        </StackPanel>
        <Grid Grid.Row="4" Grid.Column="2" ColumnDefinitions="Auto,*,Auto" Margin="0,8,0,0">
            <Button Grid.Column="0" Content="Play" Classes="play" Command="{Binding PlayCommand}" MinWidth="100"
                    FontWeight="Bold" HorizontalContentAlignment="Center"/>
            <Button Grid.Column="2" Content="{Binding DeleteButtonText}" Classes="danger" Command="{Binding DeleteCommand}"/>
        </Grid>

        <!-- Open data folders (per project, shared across its installed versions) -->
        <Grid Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" ColumnDefinitions="*,Auto" Margin="0,10,0,0">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Open folder:" VerticalAlignment="Center" Opacity="0.8"/>
                <Button Content="Data" Command="{Binding OpenDataFolderCommand}"/>
                <Button Content="Replays" Command="{Binding OpenReplaysFolderCommand}"/>
                <Button Content="Maps" Command="{Binding OpenMapsFolderCommand}"/>
                <Button Content="Saves" Command="{Binding OpenSavesFolderCommand}"/>
            </StackPanel>
            <Button Grid.Column="1" Content="Check for launcher updates" Command="{Binding CheckForLauncherUpdateCommand}"/>
        </Grid>

        <!-- Status + progress -->
        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,12,0,0" Spacing="4">
            <ProgressBar Minimum="0" Maximum="100" Value="{Binding Progress}" IsIndeterminate="{Binding IsBusy}" Height="6"/>
            <TextBlock Text="{Binding Status}" TextWrapping="Wrap"/>
            <TextBox x:Name="SessionLogTextBox"
                     Text="{Binding SessionLog, Mode=OneWay}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     FontFamily="Consolas"
                     FontSize="11"
                     MinHeight="120"
                     MaxHeight="150"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
        </StackPanel>
    </Grid>

    </DockPanel>
</Window>
